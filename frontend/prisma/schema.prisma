// Prisma schema for Construction AI — MongoDB + NextAuth
// Apply changes with: npx prisma db push  (MongoDB does not use migrations)

generator client {
  // Prisma v7 generator — outputs to src/generated/prisma
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  // Connection URL is supplied to the CLI via prisma.config.ts and to the
  // runtime PrismaClient via datasourceUrl in the constructor (see src/lib/prisma.ts).
}

// ── Application model ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// Hashed with bcryptjs — never stored as plain text
  password      String?
  /// One of: ADMIN | PROFESSIONAL | CLIENT
  role          String    @default("CLIENT")

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── NextAuth adapter models ────────────────────────────────────────────────
// Required by @auth/prisma-adapter even when using JWT strategy, so that
// OAuth providers and verification flows work if added later.

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
